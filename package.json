{
  "name": "zkusd-core",
  "version": "0.4.0",
  "description": "A TypeScript library for Node and Web (with a CLI).",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "rm -rf dist && tsup && node scripts/build-package-json.js",
    "format": "prettier --write --ignore-unknown **/*",
    "release": "changeset version && changeset publish",
    "buildw": "tsc --watch",
    "coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test": "npm run build && NODE_NO_WARNINGS=1 node --loader=ts-node/esm --enable-source-maps --test",
    "test:unit": "npm run build && NODE_NO_WARNINGS=1 node --loader=ts-node/esm --enable-source-maps --test build/src/tests/unit/**/*.test.js",
    "test:integration:lightnet:functional:happy": "npm run build && NODE_NO_WARNINGS=1 node --loader=ts-node/esm --enable-source-maps --test build/src/tests/integration/functional/happy-path.test.js",
    "test:integration:lightnet:functional:sad": "npm run build && NODE_NO_WARNINGS=1 node --loader=ts-node/esm --enable-source-maps --test build/src/tests/integration/functional/sad-path.test.js",
    "testw": "npm run build && node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "npx eslint src/* --fix"
  },
  "bin": {
    "zkusd-cli": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "node": "./dist/node/index.node.js",
      "browser": "./dist/web/index.web.js",
      "default": "./dist/node/index.node.js"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@types/bun": "latest",
    "@types/express": "4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.1",
    "commander": "^13.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "express": "^4.21.2",
    "o1js": "^2.2.0"
  },
  "dependencies": {
    "@minatokens/token": "^0.5.5",
    "mina-signer": "^3.0.7",
    "ts-node": "^10.9.2",
    "zkcloudworker": "^0.24.3"
  },
  "module": "index.ts"
}
