{
  "name": "test-core",
  "version": "0.1.0",
  "description": "A TypeScript library for Node and Web (with a CLI).",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "rm -rf dist && tsup && node scripts/build-package-json.js",
    "test": "jest",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "release": "changeset version && changeset publish"
  },
  "bin": {
    "zkusd-cli": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "node": "./dist/node/index.node.js",
      "browser": "./dist/web/index.web.js",
      "default": "./dist/node/index.node.js"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@types/express": "4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.1",
    "commander": "^13.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "express": "^4.21.2",
    "@minatokens/storage": "^0.16.16",
    "o1js": "^2.2.0"
  },
  "dependencies": {
    "@minatokens/storage": "^0.16.16",
    "@minatokens/token": "^0.16.16",
    "mina-signer": "^3.0.7",
    "ts-node": "^10.9.2",
    "zkcloudworker": "^0.24.3"
  },
  "module": "index.ts"
}